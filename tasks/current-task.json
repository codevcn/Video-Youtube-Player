{
  "feature": "subtitle_display_customization",
  "description": "Add a gesture-triggered subtitle customization panel to a YouTube video player.",
  "trigger": {
    "gesture": "swipe_right",
    "start_area": "left_edge_of_video",
    "action": "open_subtitle_customization_panel"
  },
  "ui": {
    "type": "overlay_sidebar",
    "purpose": "adjust_subtitle_display",
    "main_panel": {
      "controls": [
        {
          "id": "subtitle_move_up",
          "type": "button",
          "icon": "arrow_up",
          "behavior": "move_subtitle_up",
          "step_px": 1
        },
        {
          "id": "subtitle_move_down",
          "type": "button",
          "icon": "arrow_down",
          "behavior": "move_subtitle_down",
          "step_px": 1
        },
        {
          "id": "subtitle_font_size",
          "type": "button",
          "label": "font_size",
          "action": "open_font_size_panel"
        },
        {
          "id": "subtitle_background_opacity",
          "type": "button",
          "label": "background_opacity",
          "action": "open_background_opacity_panel"
        }
      ]
    },
    "sub_panels": [
      {
        "id": "font_size_panel",
        "type": "vertical_control_panel",
        "controls": [
          {
            "id": "font_size_increase",
            "type": "button",
            "symbol": "+",
            "position": "top",
            "behavior": "increase_font_size"
          },
          {
            "id": "font_size_decrease",
            "type": "button",
            "symbol": "-",
            "position": "bottom",
            "behavior": "decrease_font_size"
          },
          {
            "id": "font_size_back",
            "type": "button",
            "label": "back",
            "action": "return_to_main_panel"
          }
        ]
      },
      {
        "id": "background_opacity_panel",
        "type": "vertical_control_panel",
        "controls": [
          {
            "id": "background_opacity_increase",
            "type": "button",
            "symbol": "+",
            "position": "top",
            "behavior": "increase_background_opacity"
          },
          {
            "id": "background_opacity_decrease",
            "type": "button",
            "symbol": "-",
            "position": "bottom",
            "behavior": "decrease_background_opacity"
          },
          {
            "id": "background_opacity_back",
            "type": "button",
            "label": "back",
            "action": "return_to_main_panel"
          }
        ]
      }
    ]
  },
  "behavior": {
    "apply_changes": "realtime",
    "playback_interruption": false,
    "gesture_conflict": "avoid_conflicts_with_existing_player_gestures",
    "code_requirements": ["clean_structure", "modular_design", "easy_to_extend", "maintainable"]
  },
  "target_element": {
    "subtitle_container": "div",
    "properties_adjusted": ["position_y", "font_size", "background_opacity"]
  }
}
